---
import type { Locale } from '../i18n';
import HeroZone from './hero/HeroZone.astro';
import Work from './sections/Work.astro';
import System from './sections/System.astro';
import Proof from './sections/Proof.astro';
import Cta from './sections/Cta.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<HeroZone locale={locale} />
<Work locale={locale} />
<System locale={locale} />
<Proof locale={locale} />
<Cta locale={locale} />
