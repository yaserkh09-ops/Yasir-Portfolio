---
import type { Locale } from '../i18n';
import Hero from './hero/Hero.astro';
import Ticker from './sections/Ticker.astro';
import Work from './sections/Work.astro';
import System from './sections/System.astro';
import Proof from './sections/Proof.astro';
import Cta from './sections/Cta.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<Hero locale={locale} />
<Ticker locale={locale} />
<Work locale={locale} />
<System locale={locale} />
<Proof locale={locale} />
<Cta locale={locale} />
