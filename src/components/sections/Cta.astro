---
import { dicts, locales, CONTACT_EMAIL, type Locale } from '../../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = dicts[locale];
const info = locales[locale];
const c = dict.cta;
---

<section id="contact" class="cta">
  <div class="container">
    <p class="mono-label cta-label">{c.label}</p>
    <h2 class="cta-heading h2">{c.heading}</h2>
    <p class="cta-line body-l">{c.line}</p>

    <div class="cta-actions">
      <a class="btn" href={`mailto:${CONTACT_EMAIL}`} data-magnetic>{c.button}</a>
      <p class="cta-email">
        <span class="caption">{c.emailLabel}</span>
        <a class="link cta-email-link ltr-island" href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
      </p>
    </div>
  </div>

  <!-- oversized sign-off mark; the underscore/kashida draws in on entry
       (single <=1s reveal per §4). Decorative — the nav carries the mark. -->
  <p class="cta-mark wordmark" aria-hidden="true" data-mark>
    {
      locale === 'en' ? (
        <>
          YASIR<span class="mark-underscore" data-mark-underscore>_</span>
        </>
      ) : (
        info.wordmark
      )
    }
  </p>
</section>

<style>
  .cta {
    padding-block: clamp(96px, 14vh, 176px) 0;
    overflow: hidden;
  }

  .cta-label {
    color: var(--c-accent);
  }

  .cta-heading {
    margin-block-start: 16px;
    max-inline-size: 24ch;
  }

  .cta-line {
    margin-block-start: 16px;
    max-inline-size: 44ch;
    color: var(--c-text-2);
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 24px 40px;
    margin-block-start: 40px;
  }

  .cta-email {
    display: grid;
    gap: 2px;
  }

  .cta-email-link {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 0.9375rem;
    display: inline-flex;
    align-items: center;
    min-block-size: var(--target-min);
  }

  .cta-mark {
    margin-block-start: clamp(48px, 8vh, 96px);
    padding-inline: var(--gutter);
    font-size: clamp(4rem, 17vw, 15rem);
    line-height: 1.1;
    /* JS clips for the draw-in; default fully visible */
  }

  .mark-underscore {
    display: inline-block;
    transform-origin: var(--origin-start);
  }
</style>
