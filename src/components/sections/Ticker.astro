---
import { dicts, type Locale } from '../../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const items = dicts[locale].ticker;
---

<section class="ticker" aria-label={locale === 'ar' ? 'الخدمات' : 'Capabilities'}>
  <div class="ticker-track" data-ticker>
    <ul class="ticker-group" role="list">
      {items.map((item) => <li class="ticker-item ui-label">{item}</li>)}
    </ul>
    <ul class="ticker-group" role="list" aria-hidden="true">
      {items.map((item) => <li class="ticker-item ui-label">{item}</li>)}
    </ul>
  </div>
</section>

<style>
  .ticker {
    overflow: hidden;
    border-block: var(--hairline) solid var(--c-line);
    padding-block: 18px;
  }

  .ticker-track {
    display: flex;
    inline-size: max-content;
    animation: ticker-scroll 36s linear infinite;
  }
  /* marquee pauses on hover and on keyboard focus within */
  .ticker:hover .ticker-track,
  .ticker:focus-within .ticker-track {
    animation-play-state: paused;
  }

  .ticker-group {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .ticker-item {
    display: flex;
    align-items: center;
    white-space: nowrap;
    font-size: 0.9375rem;
    color: var(--c-text);
  }

  /* separator = the Stroke glyph (§4), non-text */
  .ticker-item::after {
    content: '';
    inline-size: 40px;
    block-size: var(--stroke-w);
    background: var(--c-accent);
    margin-inline: 40px;
  }

  @keyframes ticker-scroll {
    to {
      transform: translateX(-50%);
    }
  }
  :root[dir='rtl'] .ticker-track {
    animation-name: ticker-scroll-rtl;
  }
  @keyframes ticker-scroll-rtl {
    to {
      transform: translateX(50%);
    }
  }

  /* reduced motion: same five claims, static, fully visible */
  @media (prefers-reduced-motion: reduce) {
    .ticker-track {
      animation: none;
      inline-size: 100%;
    }
    .ticker-group {
      flex-wrap: wrap;
      row-gap: 12px;
    }
    .ticker-group[aria-hidden] {
      display: none;
    }
    .ticker-item::after {
      margin-inline: 16px;
      inline-size: 24px;
    }
    .ticker-item:last-child::after {
      display: none;
    }
    .ticker-item {
      white-space: normal;
    }
  }
</style>
