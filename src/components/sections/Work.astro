---
import { dicts, type Locale } from '../../i18n';
import CardArt from './CardArt.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = dicts[locale];
const w = dict.work;
---

<section id="work" class="work container">
  <header class="work-header">
    <h2 class="h2">{w.heading}</h2>
    <p class="work-line body-l">{w.line}</p>
  </header>

  <ol class="work-grid" role="list">
    {
      w.cards.map((card, i) => (
        <li class="work-card" data-work-card>
          <div class="card-media" data-card-media>
            <div class="card-media-inner" data-card-media-inner>
              <CardArt index={i} client={card.client} />
            </div>
          </div>
          <h3 class="card-title">
            {/* no-JS fallback: falls through to the contact section;
                scripts/modal.ts intercepts and opens this card's dialog */}
            <a class="card-anchor" href="#contact" aria-haspopup="dialog">
              {card.client}
            </a>
          </h3>
          <p class="card-meta mono-label">
            {card.client} · {card.sector} · {card.year}
          </p>
          <p class="card-line">{card.line}</p>
          <p class="card-cta ui-label" aria-hidden="true">
            {w.cardCta}
            <svg class="card-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M2 8h11M9 3l5 5-5 5" fill="none" stroke="currentColor" stroke-width="1.5" />
            </svg>
          </p>
          <span class="card-hairline" aria-hidden="true" />

          <dialog class="work-modal glass" data-work-modal aria-labelledby={`wm-title-${i}`}>
            <button type="button" class="wm-close" data-modal-close aria-label={w.modalClose}>
              <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M3 3l10 10M13 3L3 13" fill="none" stroke="currentColor" stroke-width="1.5" />
              </svg>
            </button>
            <p class="wm-meta mono-label">
              {card.client} · {card.sector} · {card.year}
            </p>
            <h3 class="wm-title h3" id={`wm-title-${i}`}>{card.client}</h3>
            <p class="wm-details">{card.details}</p>
            {
              card.url && (
                <a class="btn wm-visit" href={card.url} target="_blank" rel="noopener">
                  {w.modalVisit}
                </a>
              )
            }
          </dialog>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .work {
    padding-block: clamp(96px, 14vh, 160px) clamp(64px, 10vh, 120px);
  }

  .work-header {
    display: grid;
    gap: 16px;
    max-inline-size: 56ch;
    margin-block-end: clamp(64px, 9vh, 112px);
  }

  .work-label {
    color: var(--c-accent);
  }

  .work-line {
    color: var(--c-text-2);
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: 24px;
    row-gap: clamp(96px, 14vh, 176px);
  }

  .work-card {
    grid-column: 1 / -1;
    position: relative;
    transition: translate var(--t-fast) var(--ease);
    --nudge: 4px;
  }
  :root[dir='rtl'] .work-card {
    --nudge: -4px;
  }

  /* alternating editorial grid — grid tracks follow writing direction,
     so the alternation mirrors automatically in RTL */
  @media (min-width: 900px) {
    .work-card:nth-child(odd) {
      grid-column: 1 / 9;
    }
    .work-card:nth-child(even) {
      grid-column: 5 / 13;
    }
  }

  .work-card:hover {
    translate: 0 -2px;
  }

  .card-media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--radius);
    /* reveal clip set by JS (motion only); default fully visible */
  }
  .card-media-inner {
    block-size: 100%;
  }

  /* title set huge over the media edge — ink, normal blend */
  .card-title {
    position: relative;
    z-index: 2;
    margin-block-start: -0.52em;
    font-size: clamp(2.25rem, 5.5vw, 4.25rem);
    line-height: 1.05;
    font-weight: var(--fw-h1);
    letter-spacing: var(--track-h1);
    pointer-events: none; /* the stretched link below handles the click */
  }
  :root[lang='ar'] .card-title {
    line-height: 1.3; /* Arabic needs the vertical room */
    margin-block-start: -0.6em;
  }
  .work-card:nth-child(even) .card-title {
    text-align: end;
  }

  .card-anchor {
    pointer-events: auto;
  }
  /* stretched link: whole card is one 44px+ target */
  .card-anchor::after {
    content: '';
    position: absolute;
    inset: -8px;
    z-index: 1;
  }
  .work-card:has(.card-anchor:focus-visible) {
    outline: 2px solid var(--c-accent);
    outline-offset: 4px;
    border-radius: var(--radius);
  }
  .card-anchor:focus-visible {
    outline: none; /* replaced by the card-level outline above */
  }

  .card-meta {
    margin-block-start: 20px;
    color: var(--c-text-3);
  }

  .card-line {
    margin-block-start: 8px;
    max-inline-size: 48ch;
    color: var(--c-text-2);
  }
  .work-card:nth-child(even) .card-meta,
  .work-card:nth-child(even) .card-line {
    margin-inline-start: auto;
    text-align: end;
    direction: inherit;
  }
  .work-card:nth-child(even) .card-line {
    max-inline-size: 48ch;
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-block-start: 16px;
    color: var(--c-text);
  }
  .work-card:nth-child(even) .card-cta {
    float: inline-end;
  }

  .card-arrow {
    transition: translate var(--t-fast) var(--ease);
  }
  :root[dir='rtl'] .card-arrow {
    transform: scaleX(-1); /* directional icon mirrors in RTL (§3.4.1) */
  }
  .work-card:hover .card-arrow {
    translate: var(--nudge) 0;
  }

  /* hairline that turns green on hover */
  .card-hairline {
    position: absolute;
    inset-inline: 0;
    inset-block-end: -24px;
    block-size: var(--hairline);
    background: var(--c-line);
    transition: background-color var(--t-fast) var(--ease);
  }
  .work-card:hover .card-hairline {
    background: var(--c-accent);
  }

  /* ---------- project modal (glass — permitted surface) ---------- */
  .work-modal {
    /* text on glass is always full ink/paper — tokens.css contrast log */
    color: var(--c-text);
    inline-size: min(92vw, 560px);
    margin: auto;
    padding: clamp(24px, 4vw, 40px);
    border: var(--glass-border);
  }
  .work-modal[open] {
    display: grid;
    gap: 14px;
    animation: wm-in 400ms var(--ease);
  }
  @keyframes wm-in {
    from {
      opacity: 0;
      transform: translateY(12px) scale(0.97);
    }
  }
  .work-modal::backdrop {
    background: color-mix(in srgb, #161513 55%, transparent);
  }

  .wm-close {
    position: absolute;
    inset-block-start: 8px;
    inset-inline-end: 8px;
    display: grid;
    place-items: center;
    inline-size: var(--target-min);
    block-size: var(--target-min);
    background: none;
    border: 0;
    color: inherit;
    cursor: pointer;
    border-radius: var(--radius);
  }

  .wm-meta {
    color: inherit;
  }

  .wm-details {
    max-inline-size: 52ch;
  }

  .wm-visit {
    justify-self: start;
    margin-block-start: 8px;
  }
</style>
