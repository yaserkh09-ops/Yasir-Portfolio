---
import { dicts, type Locale } from '../../i18n';
import CardArt from './CardArt.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = dicts[locale];
const w = dict.work;

// bento rhythm: wide/narrow alternating per row across the six cards
const spans = ['wide', 'narrow', 'narrow', 'wide', 'wide', 'narrow'];

// Native widths of the capture sources. Screenshots display capped near
// 1.3x native (centered on dotted paper) — crisp instead of stretched.
const SHOT_W: Record<string, number> = {
  najdhands: 331,
  sipha: 465,
  fourcolors: 573,
  anjal: 330,
  alreaiah: 476,
  abdulilah: 251,
};
const shotStyle = (path: string | null) => {
  if (!path) return undefined;
  const key = Object.keys(SHOT_W).find((k) => path.includes(k));
  // never upscale past native — soft captures read as bad quality
  return key ? `--shotw: ${SHOT_W[key]}px` : undefined;
};
---

<section id="work" class="work container">
  <header class="work-header">
    <h2 class="h2">{w.heading}</h2>
    <p class="work-line body-l">{w.line}</p>
  </header>

  <ol class="work-grid" role="list">
    {
      w.cards.map((card, i) => (
        <li class:list={['work-card', `is-${spans[i]}`]} data-work-card>
          <div class="card-head">
            <h3 class="card-title h3">
              {/* no-JS fallback: falls through to the contact section;
                  scripts/modal.ts intercepts and opens this card's dialog */}
              <a class="card-anchor" href="#contact" aria-haspopup="dialog">
                {card.client}
              </a>
            </h3>
            <span class="card-expand" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
                <path
                  d="M9.5 3H13v3.5M13 3L8.5 7.5M6.5 13H3V9.5M3 13l4.5-4.5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                />
              </svg>
            </span>
          </div>
          <p class="card-meta mono-label">
            {card.client} · {card.sector} · {card.year}
          </p>
          <div class="card-media" data-card-media>
            <div class="card-media-inner" data-card-media-inner>
              {
                card.image ? (
                  <img
                    class="card-shot"
                    src={card.image}
                    alt={`${card.client} — ${w.shotAlt}`}
                    style={shotStyle(card.image)}
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <CardArt index={i} client={card.client} />
                )
              }
            </div>
          </div>

          {/* data-lenis-prevent: the smooth-scroll library must not hijack
              wheel events over the sheet — without it the modal cannot be
              scrolled with a mouse on desktop */}
          <dialog
            class="work-modal glass"
            data-work-modal
            data-lenis-prevent
            aria-labelledby={`wm-title-${i}`}
            tabindex="-1"
          >
            <button type="button" class="wm-close" data-modal-close aria-label={w.modalClose}>
              <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M3 3l10 10M13 3L3 13" fill="none" stroke="currentColor" stroke-width="1.5" />
              </svg>
            </button>

            <div class="wm-grid">
              <div class="wm-main">
                <p class="wm-meta mono-label">
                  {card.client} · {card.sector} · {card.year}
                </p>
                <h3 class="wm-title h3" id={`wm-title-${i}`}>{card.client}</h3>
                <p class="wm-details">{card.details}</p>
                <p class="wm-label ui-label">{w.processLabel}</p>
                {card.process.map((s) => <p class="wm-details wm-story">{s}</p>)}
                <p class="wm-takeaway">
                  <span class="wm-label ui-label">{w.takeawayLabel}</span>
                  {card.takeaway}
                </p>
              </div>

              <aside class="wm-side">
                <p class="wm-label ui-label">{w.scopeLabel}</p>
                <ul class="wm-bullets" role="list">
                  {
                    card.scope.map((b) => (
                      <li class="wm-bullet">
                        <svg class="wm-check" width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
                          <path d="M2.5 7.5L5.5 10.5L11.5 3.5" fill="none" stroke="currentColor" stroke-width="2" />
                        </svg>
                        {b}
                      </li>
                    ))
                  }
                </ul>
                <p class="wm-label ui-label">{w.toolsLabel}</p>
                <ul class="wm-tools" role="list">
                  {card.tools.map((t) => <li class="wm-tool ui-label">{t}</li>)}
                </ul>
              </aside>
            </div>

            <div class="wm-ctas">
              {
                card.url && (
                  <a class="btn" href={card.url} target="_blank" rel="noopener">
                    {w.modalVisit}
                  </a>
                )
              }
              <a
                class:list={['btn', { 'btn-ghost': !!card.url }]}
                href="#contact"
                data-modal-contact
              >
                {w.modalContact}
              </a>
            </div>

            <div class="wm-art" aria-hidden="true">
              {
                card.image ? (
                  <img
                    class="card-shot"
                    src={card.image}
                    alt=""
                    style={shotStyle(card.image)}
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <CardArt index={i} client={card.client} variant="m" />
                )
              }
            </div>
            {
              card.gallery.length > 0 && (
                <div class="wm-gallery" aria-hidden="true">
                  {card.gallery.map((g) => (
                    <div class="wm-tile">
                      <img
                        class="card-shot"
                        src={g}
                        alt=""
                        style={shotStyle(g)}
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                  ))}
                </div>
              )
            }
          </dialog>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .work {
    padding-block: clamp(96px, 14vh, 160px) clamp(64px, 10vh, 120px);
  }

  .work-header {
    display: grid;
    gap: 16px;
    max-inline-size: 56ch;
    margin-block-end: clamp(40px, 6vh, 72px);
  }

  .work-line {
    color: var(--c-text-2);
  }

  /* ---------- bento grid ---------- */
  .work-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 24px;
  }

  .work-card {
    grid-column: 1 / -1;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: clamp(20px, 2.5vw, 28px);
    background: var(--c-card);
    border: var(--hairline) solid var(--c-line);
    border-radius: var(--radius-panel);
    transition:
      translate var(--t-fast) var(--ease),
      border-color var(--t-fast) var(--ease);
    --nudge: 2px;
  }
  :root[dir='rtl'] .work-card {
    --nudge: -2px;
  }

  /* grid tracks follow writing direction — the bento mirrors in RTL free */
  @media (min-width: 900px) {
    .work-card.is-wide {
      grid-column: span 7;
    }
    .work-card.is-narrow {
      grid-column: span 5;
    }
  }

  .work-card:hover {
    translate: 0 -2px;
    border-color: var(--c-accent);
  }

  .card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .card-title {
    font-weight: 600;
  }

  .card-anchor {
    pointer-events: auto;
  }
  /* stretched link: the whole card is one 44px+ target */
  .card-anchor::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .work-card:has(.card-anchor:focus-visible:not(.no-focus-ring)) {
    outline: 2px solid var(--c-accent);
    outline-offset: 2px;
  }
  .card-anchor:focus-visible {
    outline: none; /* replaced by the card-level outline above */
  }

  /* Stripe-style expand affordance, top-inline-end */
  .card-expand {
    display: grid;
    place-items: center;
    inline-size: 36px;
    block-size: 36px;
    flex-shrink: 0;
    border: var(--hairline) solid var(--c-line);
    border-radius: var(--radius);
    color: var(--c-text-2);
    transition:
      color var(--t-fast) var(--ease),
      border-color var(--t-fast) var(--ease),
      translate var(--t-fast) var(--ease);
  }
  .work-card:hover .card-expand {
    color: var(--c-accent);
    border-color: var(--c-accent);
    translate: var(--nudge) calc(-1 * var(--nudge));
  }

  .card-meta {
    color: var(--c-text-3);
  }
  /* AR: sectors are Arabic — sibling treatment, never letter-spaced,
     natural RTL reading with the client name as a Latin island */
  :global(:root[lang='ar']) .card-meta,
  :global(:root[lang='ar']) .wm-meta {
    font-family: var(--font-sans);
    letter-spacing: 0;
    text-transform: none;
    font-weight: 500;
    direction: inherit;
  }

  .card-media {
    margin-block-start: 8px;
    block-size: clamp(220px, 26vw, 340px);
    overflow: hidden;
    border: var(--hairline) solid var(--c-line); /* defines the plate edge */
    border-radius: var(--radius);
    /* dotted paper behind the framed captures — brand texture */
    background-image: radial-gradient(
      color-mix(in srgb, var(--c-text) 14%, transparent) 1px,
      transparent 1.5px
    );
    background-size: 14px 14px;
    /* reveal clip set by JS (motion only); default fully visible */
  }
  .card-media-inner {
    block-size: 100%;
    display: grid;
    place-items: center;
    padding: 16px;
  }
  .card-media-inner :global(svg) {
    inline-size: 100%;
    block-size: 100%;
  }

  /* screenshots render capped near native width — crisp, never stretched */
  .card-shot {
    inline-size: auto;
    block-size: auto;
    max-inline-size: min(100%, var(--shotw, 100%));
    max-block-size: 100%;
    border: var(--hairline) solid var(--c-line);
    border-radius: 4px;
    background: var(--c-card);
  }

  /* ---------- project modal: a bottom sheet on EVERY viewport ---------- */
  .work-modal {
    /* text on glass is always full ink/paper — tokens.css contrast log */
    color: var(--c-text);
    inline-size: min(100vw, 880px);
    /* override the UA dialog max-width (100% - 6px - 2em) so the sheet
       truly spans the screen on mobile */
    max-inline-size: min(100vw, 880px);
    max-block-size: min(88svh, 820px);
    /* consistent sheet presence — short content can't shrink it */
    min-block-size: min(55svh, 520px);
    overflow: auto;
    margin: auto;
    margin-block-end: 0; /* docked to the bottom of the screen */
    padding: clamp(24px, 4vw, 48px);
    border: var(--glass-border);
    border-block-end: 0;
    border-start-start-radius: var(--radius-panel);
    border-start-end-radius: var(--radius-panel);
    border-end-start-radius: 0;
    border-end-end-radius: 0;
  }
  /* the container holds focus on open (no ring on the close button) */
  .work-modal:focus,
  .work-modal:focus-visible {
    outline: none;
  }

  .work-modal[open] {
    display: grid;
    gap: clamp(24px, 4vh, 36px);
    align-content: start;
    /* Stripe-style entrance: slides up smoothly from the screen edge */
    animation: wm-in 600ms var(--ease);
  }
  @keyframes wm-in {
    from {
      transform: translateY(100%);
    }
  }
  .work-modal::backdrop {
    background: color-mix(in srgb, #161513 55%, transparent);
    animation: wm-fade 450ms var(--ease);
  }
  @keyframes wm-fade {
    from {
      opacity: 0;
    }
  }

  .wm-close {
    position: absolute;
    inset-block-start: 8px;
    inset-inline-end: 8px;
    display: grid;
    place-items: center;
    inline-size: var(--target-min);
    block-size: var(--target-min);
    background: none;
    border: 0;
    color: inherit;
    cursor: pointer;
    border-radius: var(--radius);
  }

  .wm-grid {
    display: grid;
    gap: 24px;
    padding-inline-end: 32px; /* clear the close button on small screens */
  }
  @media (min-width: 760px) {
    .wm-grid {
      grid-template-columns: minmax(0, 3fr) minmax(0, 2fr);
      gap: 24px 48px;
      padding-inline-end: 0;
    }
  }

  .wm-main {
    display: grid;
    gap: 14px;
    align-content: start;
  }

  .wm-meta {
    color: inherit;
  }

  .wm-details {
    max-inline-size: 52ch;
  }

  /* section labels inside the sheet — full ink/paper on glass */
  .wm-label {
    color: inherit;
    margin-block-start: 10px;
    padding-block-end: 6px;
    border-block-end: var(--hairline) solid color-mix(in srgb, currentColor 14%, transparent);
  }

  /* the reader's line: how this maps to their own project */
  .wm-takeaway {
    max-inline-size: 52ch;
    margin-block-start: 10px;
    padding-inline-start: 14px;
    border-inline-start: var(--stroke-w) solid var(--c-accent); /* the Stroke, non-text */
    font-weight: 500;
    display: grid;
    gap: 6px;
  }
  .wm-takeaway .wm-label {
    margin-block-start: 0;
    padding-block-end: 0;
    border-block-end: 0;
  }

  .wm-side {
    display: grid;
    gap: 12px;
    align-content: start;
  }

  .wm-tools {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .wm-tool {
    border: var(--hairline) solid color-mix(in srgb, currentColor 30%, transparent);
    border-radius: var(--radius);
    padding: 6px 12px;
    direction: ltr; /* platform names are Latin marks in both trees */
  }
  :global(:root[lang='ar']) .wm-tool {
    direction: rtl; /* Arabic chips read naturally; Latin ones are islands */
  }

  .wm-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  /* secondary CTA: quiet outline sibling of .btn */
  .btn-ghost {
    background: transparent;
    color: var(--c-text);
    border: var(--hairline) solid color-mix(in srgb, currentColor 30%, transparent);
  }
  .btn-ghost::after {
    background: var(--c-accent);
  }

  .wm-bullets {
    display: grid;
    gap: 12px;
    align-content: start;
  }

  .wm-bullet {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  /* green check = pass-state semantics; non-text on glass (>=3:1 ok) */
  .wm-check {
    flex-shrink: 0;
    color: var(--c-accent);
    translate: 0 1px;
  }

  .wm-art,
  .wm-tile {
    display: grid;
    place-items: center;
    padding: clamp(14px, 2.5vw, 24px);
    border: var(--hairline) solid var(--c-line);
    border-radius: var(--radius);
    background-image: radial-gradient(
      color-mix(in srgb, var(--c-text) 14%, transparent) 1px,
      transparent 1.5px
    );
    background-size: 14px 14px;
  }
  .wm-art :global(svg) {
    inline-size: 100%;
    block-size: 100%;
  }

  .wm-gallery {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 250px), 1fr));
  }
</style>
