---
import { dicts, type Locale } from '../../i18n';
import StatusTerminal from '../StatusTerminal.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const d = dicts[locale].hero;
---

<!-- The particle field behind this section lives in HeroZone.astro — it
     spans the hero AND the statement section below it. -->
<section class="hero">
  <div class="hero-inner container">
    <div class="hero-copy">
      <p class="hero-eyebrow mono-label">{d.eyebrow}</p>
      <h1 class="hero-h1 h1">
        {
          d.h1Lines.map((line) => (
            <span class="h1-line" data-h1-line>
              <span class="h1-line-inner">{line}</span>
            </span>
          ))
        }
      </h1>

      <div class="hero-cta glass">
        <a class="btn" href="#contact" data-magnetic data-contact-open>{d.cta}</a>
        <p class="hero-cta-note ui-label">{d.ctaNote}</p>
      </div>
    </div>

    <div class="hero-terminal">
      <StatusTerminal locale={locale} />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-block-size: 100svh;
    display: grid;
  }

  .hero-inner {
    position: relative;
    z-index: var(--z-content);
    display: grid;
    gap: clamp(40px, 6vh, 72px);
    align-content: end;
    padding-block: 128px clamp(32px, 6vh, 64px);
  }

  @media (min-width: 1024px) {
    .hero-inner {
      grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
      align-items: end;
    }
  }

  .hero-copy {
    display: grid;
    gap: clamp(20px, 3vh, 32px);
    justify-items: start;
  }

  .hero-eyebrow {
    color: var(--c-accent);
    /* kicker locks to its headline: tighter than the grid's uniform gap */
    margin-block-end: -12px;
    text-wrap: balance;
  }
  /* AR: the LTR eyebrow aligns to the right edge with the RTL composition */
  :global(:root[lang='ar']) .hero-eyebrow {
    text-align: end;
  }

  .h1-line {
    display: block;
    /* JS sets the animated clip; default is fully visible (no-JS / PRM) */
  }
  .h1-line-inner {
    display: inline-block;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 20px;
    padding: 14px;
    color: var(--c-text); /* glass text rule */
  }
  /* narrow screens: the note reflows below the intact button */
  @media (max-width: 479px) {
    .hero-cta {
      flex-wrap: wrap;
    }
    .hero-cta-note {
      padding-inline-end: 0;
    }
  }

  .hero-cta-note {
    padding-inline-end: 10px;
  }

  .hero-terminal {
    justify-self: end;
    align-self: end;
    inline-size: 100%;
    display: flex;
    justify-content: flex-end;
  }

  @media (max-width: 1023px) {
    .hero-terminal {
      justify-content: stretch;
    }
  }
</style>
