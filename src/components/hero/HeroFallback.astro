---
/**
 * Static render of the field: the brand grid as a dot matrix with a few
 * signal-green points. Always painted first underneath the canvas (zero
 * CLS) and remains the field for reduced-motion, WebGL failure, and
 * deviceMemory < 4. Tiles at a fixed 16px cell regardless of container
 * height — the field now spans the hero AND the statement section.
 */
const greens = [
  ['12%', '22%'],
  ['27%', '15%'],
  ['42%', '26%'],
  ['57%', '18%'],
  ['71%', '24%'],
  ['86%', '16%'],
  ['22%', '48%'],
  ['64%', '55%'],
  ['38%', '68%'],
  ['79%', '62%'],
];
---

<svg class="hero-fallback" aria-hidden="true" focusable="false">
  <defs>
    <pattern id="hg" width="16" height="16" patternUnits="userSpaceOnUse">
      <circle cx="2" cy="2" r="1.1" fill="var(--gl-point)" opacity="0.22"></circle>
    </pattern>
  </defs>
  <rect width="100%" height="100%" fill="url(#hg)"></rect>
  {greens.map(([x, y]) => <circle cx={x} cy={y} r="2" fill="var(--gl-accent)" />)}
</svg>

<style>
  .hero-fallback {
    position: absolute;
    inset: 0;
    inline-size: 100%;
    block-size: 100%;
  }
</style>
