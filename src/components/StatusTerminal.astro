---
import { dicts, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const d = dicts[locale].hero;

/**
 * Rows come from the locale dict (fully Arabic on /ar/) and map to
 * /public/metrics.json (see the notes in that file — the two Lighthouse
 * rows are measured, satisfaction is the studio's stated commitment).
 * Server-rendered values are honest em-dashes; scripts/terminal.ts fills
 * real values only when they exist. Targets live in terminal.ts:
 * performance >= 95, accessibility = 100, satisfaction = 100.
 */
const rows = d.terminalRows;
---

<aside class="terminal glass" aria-label={d.terminalAria} data-terminal data-not-measured={d.notMeasured}>
  <!-- all card copy is locale-aware (fully Arabic on /ar/); values stay LTR islands -->
  <p class="t-title ui-label">{d.terminalTitle}</p>
  <div class="t-body" data-terminal-body>
    <p class="t-cmd ui-label">
      <span class="t-prompt" aria-hidden="true">✓&nbsp;</span><span data-t-cmd>{d.terminalCmd}</span>
    </p>
    <ul role="list">
      {
        rows.map((r) => (
          <li class="t-row ui-label" data-t-row>
            <span class="t-key" data-t-key>{r.key}</span>
            <span class="t-leader" aria-hidden="true" />
            <span class="t-val ltr-island" data-t-val={r.metric}>
              —
            </span>
            <span class="t-dot" data-t-dot hidden aria-hidden="true" />
          </li>
        ))
      }
    </ul>
  </div>
  <p class="t-note ui-label">{d.metricsNote}</p>
  <p class="sr-only" data-terminal-sr aria-live="polite"></p>
</aside>

<style>
  .terminal {
    /* Text on glass is always full ink/paper — tokens.css contrast log */
    color: var(--c-text);
    padding: 20px 24px;
    inline-size: min(100%, 430px);
    display: grid;
    gap: 14px;
  }

  .t-title {
    color: inherit;
    padding-block-end: 10px;
    border-block-end: var(--hairline) solid color-mix(in srgb, currentColor 14%, transparent);
  }

  /* Arabic needs a touch more size at label scale for legibility.
     Weights pinned to the PRELOADED Arabic faces (700/400) so this
     above-the-fold text can never swap-shift (CLS 0). */
  :global(:root[lang='ar']) .t-title {
    font-size: 0.9375rem;
    font-weight: 700;
  }
  :global(:root[lang='ar']) .t-cmd {
    font-size: 0.9375rem;
    font-weight: 400;
  }
  /* AR rows: same preloaded-face pinning (400) — never swap-shifts */
  :global(:root[lang='ar']) .t-row {
    font-size: 0.875rem;
    font-weight: 400;
  }
  /* values are Latin digits — keep them mono even between Arabic labels */
  :global(:root[lang='ar']) .t-val {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }

  .t-body {
    display: grid;
    gap: 8px;
    min-block-size: 7.2em; /* rows reserved — typing can't shift layout */
  }

  .t-cmd {
    color: inherit;
  }

  .t-prompt {
    color: var(--c-accent);
  }

  .t-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    color: inherit;
  }

  .t-leader {
    flex: 1;
    border-block-end: var(--hairline) dashed color-mix(in srgb, currentColor 25%, transparent);
    translate: 0 -4px;
  }

  .t-val {
    font-variant-numeric: tabular-nums slashed-zero;
  }

  /* pass-dot: green, non-text (3.11:1 / 3.23:1 vs worst-case glass — OK) */
  .t-dot {
    inline-size: 8px;
    block-size: 8px;
    border-radius: 50%;
    background: var(--c-accent);
    align-self: center;
  }
  .t-dot.is-pass {
    animation: dot-spring 500ms var(--ease) both;
  }
  @keyframes dot-spring {
    0% {
      transform: scale(0);
    }
    60% {
      transform: scale(1.5);
    }
    100% {
      transform: scale(1);
    }
  }

  .t-note {
    color: inherit; /* full ink/paper — stone fails on glass */
    opacity: 1;
    font-weight: 500;
  }

  /* typing caret, added by terminal.ts during the typed phase */
  :global(.t-caret) {
    display: inline-block;
    inline-size: 0.55em;
    block-size: 1em;
    translate: 2px 2px;
    background: var(--c-accent);
  }
</style>
