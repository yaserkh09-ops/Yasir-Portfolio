---
// Root: meta-refresh to /en/ with a pre-paint Arabic-preference check.
// Both trees are first-class; this page is never seen for more than a tick.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>YASIR_ · ياسر</title>
    <meta name="robots" content="noindex" />
    <link rel="alternate" hreflang="en" href={new URL('/en/', Astro.site)} />
    <link rel="alternate" hreflang="ar" href={new URL('/ar/', Astro.site)} />
    <link rel="alternate" hreflang="x-default" href={new URL('/en/', Astro.site)} />
    <script is:inline>
      (function () {
        var langs = navigator.languages || [navigator.language || 'en'];
        var ar = langs.some(function (l) {
          return /^ar\b/i.test(l);
        });
        location.replace(ar ? '/ar/' : '/en/');
      })();
    </script>
    <meta http-equiv="refresh" content="0;url=/en/" />
  </head>
  <body>
    <p><a href="/en/">English</a> · <a href="/ar/" lang="ar" dir="rtl">العربية</a></p>
  </body>
</html>
