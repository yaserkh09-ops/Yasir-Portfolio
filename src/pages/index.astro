---
// Root: everyone lands on /ar/ — Arabic is the site's default tree
// (owner decision). English remains one tap away via the nav toggle.
---

<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ياسر · YASIR_</title>
    <meta name="robots" content="noindex" />
    <link rel="alternate" hreflang="en" href={new URL('/en/', Astro.site)} />
    <link rel="alternate" hreflang="ar" href={new URL('/ar/', Astro.site)} />
    <link rel="alternate" hreflang="x-default" href={new URL('/ar/', Astro.site)} />
    <script is:inline>
      location.replace('/ar/');
    </script>
    <meta http-equiv="refresh" content="0;url=/ar/" />
  </head>
  <body>
    <p><a href="/ar/" lang="ar" dir="rtl">العربية</a> · <a href="/en/">English</a></p>
  </body>
</html>
